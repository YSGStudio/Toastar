# Supabase 프로젝트 설정 (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Settings > API > JWT Settings 의 "JWT Secret" (학생 커스텀 로그인 토큰 서명용)
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# 작품 파일 저장용 Storage 버킷 이름 (supabase/migrations 에서 생성)
NEXT_PUBLIC_ARTWORK_BUCKET=artworks

# 학교 기준 시간대 (로그인 차단 시간 계산 기준)
SCHOOL_TIMEZONE=Asia/Seoul

# 관리자 계정 최초 1회 발급용 코드 (회원가입 시 "관리자로 가입"에 입력). 관리자가 이미 있으면 무시된다.
ADMIN_SETUP_CODE=CHANGE_ME_TO_A_RANDOM_SECRET

# 작품 설명(AI 도움/스스로 한 점)에 욕설·비속어·타인 비난이 있는지 검사하는 데 사용 (OpenAI API 키)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
